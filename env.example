# ===========================================
# LSRP Number Bot - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env
#
# Never commit .env to version control!
# ===========================================

# Required - Discord Bot Token
# Get from: https://discord.com/developers/applications → Your App → Bot → Reset Token
DISCORD_TOKEN=your_bot_token_here

# Required - Database Password
DATABASE_PASSWORD=your_database_password

# Optional - Database connection (defaults shown)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=lsrp_bot
DATABASE_USER=root

# Optional - Override config.json values
# STARTING_NUMBER=2000
# SKIP_ROLE_IDS=role_id_1,role_id_2,role_id_3
